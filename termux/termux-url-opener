#!/data/data/com.termux/files/usr/bin/bash
# Termux URL opener - handles both video URLs and channel refresh commands
# Place at ~/bin/termux-url-opener

INPUT="$1"
BASE_DIR="$HOME/storage/shared/Podcasts"
SCRIPT_DIR="$HOME/youtube_podcasts"

echo "================================================"
echo "  YouTube Audio Downloader"
echo "================================================"
echo ""

cd "$SCRIPT_DIR" 2>/dev/null || cd "$HOME"

# Check if this is a channel refresh command (format: "REFRESH:channel_url:folder_name")
if echo "$INPUT" | grep -q "^REFRESH:"; then
    CHANNEL_URL=$(echo "$INPUT" | cut -d':' -f2-)
    FOLDER_NAME=$(echo "$CHANNEL_URL" | sed 's|.*/@@*||' | sed 's|[^a-zA-Z0-9_-]|_|g')
    OUTPUT_DIR="$BASE_DIR/$FOLDER_NAME"
    mkdir -p "$OUTPUT_DIR"

    echo "Refreshing channel: $CHANNEL_URL"
    echo "Saving to: $OUTPUT_DIR"
    echo ""

    python download_audio.py --max-episodes 3 --output-dir "$OUTPUT_DIR" 2>&1
else
    # Regular video URL
    URL="$INPUT"

    # Check if a folder name is appended (format: "URL|||folder_name")
    if echo "$INPUT" | grep -q "|||"; then
        URL=$(echo "$INPUT" | cut -d'|' -f1-3 | sed 's/|||$//')
        URL=$(echo "$INPUT" | sed 's/|||.*//')
        FOLDER_NAME=$(echo "$INPUT" | sed 's/.*|||//')
    else
        FOLDER_NAME="General"
    fi

    OUTPUT_DIR="$BASE_DIR/$FOLDER_NAME"
    mkdir -p "$OUTPUT_DIR"

    echo "URL: $URL"
    echo "Saving to: $OUTPUT_DIR"
    echo ""

    python download_audio.py --url "$URL" --output-dir "$OUTPUT_DIR" 2>&1
fi

STATUS=$?
echo ""
if [ $STATUS -eq 0 ]; then
    echo "Done! Check your Podcasts folder."
else
    echo "Something went wrong. Check the error above."
fi
echo ""
echo "Press Enter to close..."
read
